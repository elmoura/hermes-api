# Chave server-to-server para rotas admin (Authorization: Bearer …)
ADMIN_API_KEY=change-me-in-production

# CORS: ver `config.cors` em src/config/config.ts — `FRONTEND_URL` + lista em CORS_ORIGIN;
# em dev, localhost/127.0.0.1 (qualquer porta) é aceite. Em prod: CORS_ORIGIN e/ou CORS_ALLOW_LOCALHOST=true
# CORS_ORIGIN=https://app.exemplo.com
# CORS_ALLOW_LOCALHOST=true

EMAIL_USER=something@mail.com
EMAIL_PASS=something
EMAIL_FROM=no-reply@falae.ai
FRONTEND_URL=http://localhost:3000
MONGO_URI=localhost:27017/falae
CONFIRM_ACCOUNT_HASH_SECRET=change-me-in-production
PASSWORD_MD5_SALT=change-me-in-production
INVITE_TOKEN_TTL_MS=172800000

# Meta / Facebook OAuth (WhatsApp Business)
META_APP_ID=2461607524299278
META_APP_SECRET=